# wecom-group-agent 配置模板
# 复制为 .env 并填入真实值：cp .env.example .env
# .env 已被 .gitignore 忽略，切勿把真实密钥提交。

# ── 适配器 / handler / 知识 / 存储 开关 ─────────────────────
# ADAPTER: kf（微信客服，官方合规 1:1，已实现）| ntwork（企微群 hook，仅 Windows，stub）
#          不设则默认 ntwork；本地模拟请用 MOCK=1（mock 不是 ADAPTER 的取值）
# MOCK=1                              # 本地模拟 MockCliAdapter（Mac 可跑）
# MOCK_SCRIPT=examples/sample.json    # mock 脚本模式；缺省为交互模式
# HANDLER: echo（复读机，离线可用）| llm（真大模型）
HANDLER=llm
# KNOWLEDGE_PROVIDER: static（默认，全量）| rag（向量检索）| structured（结构化商品库）| hybrid（组合）
# KNOWLEDGE_PROVIDER=static
# STORE: 会话存储；sqlite 时持久化、重启恢复（默认内存版）
# STORE=sqlite
# SQLITE_PATH=data/sessions.db

# ── LLM（当前用 StepFun 阶跃星辰，OpenAI 兼容）────────────
LLM_BASE_URL=https://api.stepfun.com/step_plan/v1
LLM_API_KEY=在这里填你的密钥
LLM_MODEL=step-3.7-flash
# LLM_TIMEOUT=60
# LLM_MAX_HISTORY=10
# 人设/知识文件（默认即可，一般改文件内容而非路径；LLM_KNOWLEDGE_FILE 仅 static 知识后端生效）
# LLM_PERSONA_FILE=prompts/persona.md
# LLM_KNOWLEDGE_FILE=prompts/knowledge.md
# 如需完全自定义 system prompt，可直接覆盖（优先级最高）：
# LLM_SYSTEM_PROMPT=...

# ── 知识检索 RAG（KNOWLEDGE_PROVIDER=rag/hybrid 时用）──────
# 需要一个 OpenAI 兼容的 embedding 端点；不配置则 RAG 自动回退全量(等价 Static)。
# LLM_EMBED_URL=https://api.openai.com/v1     # 默认取 LLM_BASE_URL
# LLM_EMBED_MODEL=text-embedding-3-small      # 改成你 embedding 供应商的模型
# RAG_TOP_K=4
# RAG_SMALL_KB_MAX=15                          # chunk 数 ≤ 此值直接全量、不检索
# RAG_TIMEOUT=30

# ── 微信客服（ADAPTER=kf，官方合规 1:1，已实现；需公网可访问回调地址）──────────
# ADAPTER=kf
# WECOM_CORP_ID=
# WECOM_KF_SECRET=
# WECOM_CALLBACK_TOKEN=
# WECOM_ENCODING_AES_KEY=
# WECOM_CALLBACK_PORT=9000
# WECOM_CALLBACK_PATH=/wecom/callback
# WECOM_TOKEN_FILE=data/wecom_kf_token.json   # 可选:多副本经此文件共享 access_token(默认仅进程内内存)

# ── 运营后台 REST API（python3 api_server.py）────────────
# ADMIN_TOKEN=                 # 鉴权 token（Bearer 或 X-Admin-Token 头）；留空=开发模式放行
# API_HOST=127.0.0.1
# API_PORT=8080

# ── 运营管理后台 Web 工作台（python3 admin_console.py）────
# CONSOLE_PASSWORD=            # 登录口令；留空回落 ADMIN_TOKEN；两者都空=开发模式放行
# CONSOLE_HOST=127.0.0.1
# CONSOLE_PORT=8090
# API_BASE=http://127.0.0.1:8080   # 指向 api_server 地址（compose 里可写 http://api:8080）
